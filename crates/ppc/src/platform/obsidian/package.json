{
  "name": "ppc-obsidian-plugin",
  "version": "0.1.0",
  "description": "Turnes obsidian into an PPC client",
  "main": "main.js",
  "scripts": {
    "build:rust": "wasm-pack -vvvvv build -d src/platform/obsidian/rust_dist --target web --no-default-features --features target-obsidian",
    "build": "npm run build:rust && mkdir -p dist && touch dist/.hotreload && cp manifest.json dist && node esbuild.config.js production",
    "dev": ""
  },
  "keywords": [
    "obsidian",
    "plugin"
  ],
  "author": "c2vi",
  "license": "MIT",
  "dependencies": {
    "@flowershow/remark-wiki-link": "^2.0.4",
    "@instantdb/admin": "^0.21.3",
    "@instantdb/react": "^0.20.28",
    "@react-oauth/google": "^0.12.2",
    "esbuild": "^0.27.3",
    "mdast": "^3.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@wasm-tool/rollup-plugin-rust": "^3.1.4",
    "binaryen": "^125.0.0",
    "builtin-modules": "3.3.0",
    "obsidian": "latest",
    "tailwindcss": "^4",
    "tslib": "^2.6.2",
    "typescript": "^5.5.4"
  }
}
